<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Nonsoinspire Foundation</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
scroll-behavior:smooth;
}

body{
font-family:Arial, sans-serif;
background:#f4f7f4;
color:#222;
line-height:1.7;
}

/* HERO SECTION */

header{
height:100vh;
background:
linear-gradient(rgba(0,0,0,0.6),rgba(0,0,0,0.6)),
url('photo1.jpg');

background-size:cover;
background-position:center;

display:flex;
justify-content:center;
align-items:center;
text-align:center;
padding:20px;
color:white;
}

.hero{
max-width:900px;
}

.hero img{
width:180px;
border-radius:25px;
margin-bottom:20px;
box-shadow:0 0 20px rgba(255,255,255,0.3);
}

.hero h1{
font-size:70px;
margin-bottom:20px;
}

.hero p{
font-size:25px;
margin-bottom:30px;
}

.btn{
display:inline-block;
padding:15px 35px;
background:#2e7d32;
color:white;
text-decoration:none;
border-radius:12px;
font-size:22px;
margin:10px;
transition:0.3s;
}

.btn:hover{
background:#145a1f;
transform:scale(1.05);
}

/* NAVIGATION */

nav{
background:#145a1f;
padding:18px;
text-align:center;
position:sticky;
top:0;
z-index:1000;
}

nav a{
color:white;
text-decoration:none;
margin:15px;
font-size:19px;
font-weight:bold;
}

nav a:hover{
color:#90ee90;
}

/* SECTION STYLE */

section{
background:white;
margin:35px;
padding:60px;
border-radius:25px;
box-shadow:0 0 15px rgba(0,0,0,0.08);
}

section h2{
font-size:45px;
margin-bottom:25px;
color:#2e7d32;
}

section p{
font-size:21px;
margin-bottom:20px;
}

/* IMPACT SECTION */

.impact-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:25px;
margin-top:30px;
}

.impact-box{
background:#2e7d32;
color:white;
padding:35px;
border-radius:20px;
text-align:center;
}

.impact-box h3{
font-size:45px;
}

/* PROGRAMS */

.program-list li{
font-size:22px;
margin-bottom:15px;
}

/* GALLERY */

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.gallery img{
width:100%;
height:280px;
object-fit:cover;
border-radius:20px;
transition:0.3s;
}

.gallery img:hover{
transform:scale(1.03);
}

/* VIDEO */

video{
width:100%;
border-radius:20px;
margin-top:20px;
}

/* AUDIO */

audio{
width:100%;
margin-top:20px;
}

/* CONTACT */

.contact-box{
background:#f0f0f0;
padding:35px;
border-radius:20px;
margin-top:20px;
}

.contact-box input,
.contact-box textarea{
width:100%;
padding:16px;
margin-top:15px;
border:none;
border-radius:10px;
font-size:18px;
}

.contact-box button{
margin-top:20px;
padding:15px 35px;
background:#2e7d32;
color:white;
border:none;
border-radius:10px;
font-size:20px;
cursor:pointer;
}

.contact-box button:hover{
background:#145a1f;
}

/* SOCIAL LINKS */

.socials{
margin-top:25px;
}

.socials a{
display:inline-block;
margin:10px;
padding:12px 20px;
background:#145a1f;
color:white;
text-decoration:none;
border-radius:10px;
font-size:18px;
}

/* FOOTER */

footer{
background:#145a1f;
color:white;
text-align:center;
padding:50px 20px;
margin-top:40px;
}

footer h3{
font-size:35px;
margin-bottom:15px;
}

/* MOBILE */

@media(max-width:768px){

.hero h1{
font-size:45px;
}

.hero p{
font-size:20px;
}

nav a{
display:block;
margin:10px 0;
}

section{
margin:15px;
padding:35px 20px;
}

section h2{
font-size:35px;
}

}

</style>

</head>

